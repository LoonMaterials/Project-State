{
  "app": "Project State",
  "contractType": "ExternalSecurityBoundary",
  "contractVersion": "0.1",
  "implementationStatus": "external_responsibility_no_bundled_scanner",
  "bundledMalwareScanning": false,
  "bundledProviders": [],
  "windowsDefenderIntegration": false,
  "requiredAcknowledgment": {
    "actorId": true,
    "timestamp": true,
    "reason": true,
    "fileVersionId": true,
    "discoveryCaseId": true
  },
  "enforcedControls": [
    "copy_original_without_moving",
    "sha256_exact_identity",
    "byte_size_exact_identity",
    "registered_managed_path",
    "block_changed_or_missing_staged_bytes",
    "append_only_acknowledgment_event"
  ],
  "forbiddenClaims": [
    "malware_free",
    "clean",
    "safe",
    "threat_free",
    "antivirus_healthy"
  ],
  "stableErrors": [
    "EXTERNAL_SECURITY_ACKNOWLEDGMENT_REQUIRED",
    "FILE_VERSION_MISMATCH",
    "STAGED_FILE_MISSING",
    "STAGING_SCOPE_REJECTED"
  ],
  "optionalFutureSecurityReceiptStorage": true,
  "forbiddenAuthority": [
    "selectProject",
    "createProject",
    "confirmDiscoveryAnswer",
    "confirmRouting",
    "approveIntake",
    "writeCore",
    "deleteOriginalFile",
    "scanArbitraryPath",
    "rewriteReceiptHistory"
  ]
}
