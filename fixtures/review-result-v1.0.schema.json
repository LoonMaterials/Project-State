{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-state://schema/review-result/1.0",
  "title": "Project State External Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "format_version", "package_id", "work_order_id", "discovery_case_id", "pack_revision", "evidence_sha256", "reviewer", "source_complete", "decisions", "relationships", "human_questions", "rejected_material"],
  "properties": {
    "format": { "const": "project-state-review-result" },
    "format_version": { "const": "1.0" },
    "package_id": { "type": "string", "minLength": 1 },
    "work_order_id": { "type": "string", "minLength": 1 },
    "discovery_case_id": { "type": "string", "minLength": 1 },
    "pack_revision": { "type": "integer", "minimum": 1 },
    "evidence_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "reviewer": { "$ref": "#/$defs/reviewer" },
    "source_complete": { "type": "boolean" },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "relationships": { "type": "array", "items": { "$ref": "#/$defs/relationship" } },
    "human_questions": { "type": "array", "items": { "$ref": "#/$defs/human_question" } },
    "rejected_material": { "type": "array", "items": { "$ref": "#/$defs/rejected_material" } }
  },
  "$defs": {
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_type"],
      "properties": {
        "reviewer_type": { "enum": ["ai", "human", "hybrid"] },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "name": { "type": "string" },
        "reviewed_at": { "type": "string" }
      }
    },
    "project_match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "canonical_name"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "canonical_name": { "type": "string", "minLength": 1 }
      }
    },
    "proposed_new_project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggested_name", "suggested_aliases", "short_summary", "supporting_chunk_ids", "reason_distinct_from_existing_projects", "related_existing_project_ids", "proposed_parent_project_id", "confidence"],
      "properties": {
        "suggested_name": { "type": "string", "minLength": 1 },
        "suggested_aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "short_summary": { "type": "string" },
        "supporting_chunk_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
        "reason_distinct_from_existing_projects": { "type": "string", "minLength": 1 },
        "related_existing_project_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "proposed_parent_project_id": { "type": ["string", "null"] },
        "project_family": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "evidence_span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chunk_id", "start", "end", "excerpt"],
      "properties": {
        "chunk_id": { "type": "string", "minLength": 1 },
        "start": { "type": "integer", "minimum": 0 },
        "end": { "type": "integer", "minimum": 0 },
        "excerpt": { "type": "string" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "concept_title", "classification", "primary_project", "additional_projects", "summary", "supporting_chunk_ids", "evidence_spans", "confidence", "reasoning_summary", "evidence_role", "personal_aether_support", "commercial_default_allowed", "requires_separate_design_review", "human_review_required"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "concept_title": { "type": "string", "minLength": 1 },
        "classification": { "enum": ["project_candidate", "existing_project_support", "reference_note", "personal_context_note", "assistant_scaffolding_noise", "rejected_noise"] },
        "primary_project": { "oneOf": [{ "$ref": "#/$defs/project_match" }, { "type": "null" }] },
        "additional_projects": { "type": "array", "items": { "$ref": "#/$defs/project_match" } },
        "proposed_new_project": { "$ref": "#/$defs/proposed_new_project" },
        "summary": { "type": "string" },
        "supporting_chunk_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
        "evidence_spans": { "type": "array", "items": { "$ref": "#/$defs/evidence_span" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasoning_summary": { "type": "string" },
        "evidence_role": { "enum": ["primary_evidence", "background_reference", "duplicate_or_confirming_reference", "validation_or_test_support", "risk_or_contradiction", "patent_licensing_or_outreach_support", "cross_project_reference", "additional_project_reference", "context_only", "noise"] },
        "personal_aether_support": { "type": "boolean" },
        "commercial_default_allowed": { "type": "boolean" },
        "requires_separate_design_review": { "type": "boolean" },
        "human_review_required": { "type": "boolean" }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relationship_id", "relationship_type", "source_decision_id", "target_decision_id", "source_project", "target_project", "supporting_chunk_ids", "summary"],
      "properties": {
        "relationship_id": { "type": "string", "minLength": 1 },
        "relationship_type": { "type": "string", "minLength": 1 },
        "source_decision_id": { "type": ["string", "null"] },
        "target_decision_id": { "type": ["string", "null"] },
        "source_project": { "oneOf": [{ "$ref": "#/$defs/project_match" }, { "type": "null" }] },
        "target_project": { "oneOf": [{ "$ref": "#/$defs/project_match" }, { "type": "null" }] },
        "supporting_chunk_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "summary": { "type": "string" }
      }
    },
    "human_question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_id", "text", "supporting_chunk_ids", "decision_ids"],
      "properties": {
        "question_id": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "supporting_chunk_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "decision_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "rejected_material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rejected_id", "title", "reason", "supporting_chunk_ids"],
      "properties": {
        "rejected_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "reason": { "type": "string" },
        "supporting_chunk_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    }
  }
}
