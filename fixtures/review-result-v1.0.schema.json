{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-state://schema/review-result/1.0",
  "title": "Project State External Review Result",
  "type": "object",
  "additionalProperties": true,
  "required": ["format", "format_version", "work_order_id", "reviewer", "source_complete", "decisions", "relationships", "human_questions", "rejected_material"],
  "properties": {
    "format": { "const": "project-state-review-result" },
    "format_version": { "const": "1.0" },
    "work_order_id": { "type": "string", "minLength": 1 },
    "reviewer": {
      "type": "object",
      "required": ["reviewer_type"],
      "properties": {
        "reviewer_type": { "enum": ["ai", "human", "hybrid"] },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "name": { "type": "string" },
        "reviewed_at": { "type": "string" }
      }
    },
    "source_complete": { "type": "boolean" },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "relationships": { "type": "array", "items": { "type": "object" } },
    "human_questions": { "type": "array", "items": { "type": "object" } },
    "rejected_material": { "type": "array", "items": { "type": "object" } }
  },
  "$defs": {
    "decision": {
      "type": "object",
      "required": ["decision_id", "concept_title", "classification", "primary_project_id", "additional_project_ids", "summary", "supporting_chunk_ids", "evidence_spans", "confidence", "reasoning_summary", "evidence_role", "personal_aether_support", "commercial_default_allowed", "requires_separate_design_review", "human_review_required"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "concept_title": { "type": "string", "minLength": 1 },
        "classification": { "enum": ["project_candidate", "existing_project_support", "reference_note", "personal_context_note", "assistant_scaffolding_noise", "rejected_noise"] },
        "primary_project_id": { "type": ["string", "null"] },
        "additional_project_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "proposed_new_project": {
          "type": "object",
          "required": ["name"],
          "properties": { "name": { "type": "string", "minLength": 1 }, "summary": { "type": "string" } }
        },
        "summary": { "type": "string" },
        "supporting_chunk_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
        "evidence_spans": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["chunk_id"],
            "properties": {
              "chunk_id": { "type": "string" },
              "start": { "type": "integer", "minimum": 0 },
              "end": { "type": "integer", "minimum": 0 },
              "excerpt": { "type": "string" }
            }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasoning_summary": { "type": "string" },
        "evidence_role": { "enum": ["primary_evidence", "background_reference", "duplicate_or_confirming_reference", "validation_or_test_support", "risk_or_contradiction", "patent_licensing_or_outreach_support", "cross_project_reference", "additional_project_reference", "context_only", "noise"] },
        "personal_aether_support": { "type": "boolean" },
        "commercial_default_allowed": { "type": "boolean" },
        "requires_separate_design_review": { "type": "boolean" },
        "human_review_required": { "type": "boolean" }
      }
    }
  }
}
